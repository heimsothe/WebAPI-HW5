    {
      "name": "GET /movies (all movies)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array with at least 1 movie', function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response).to.be.an('array');",
              "    pm.expect(response.length).to.be.at.least(1);",
              "});",
              "",
              "pm.test('Each movie has HW5 fields (avgRating) and NO reviews', function () {",
              "    const movies = pm.response.json();",
              "    movies.forEach(m => {",
              "        pm.expect(m).to.have.property('title');",
              "        pm.expect(m).to.have.property('releaseDate');",
              "        pm.expect(m).to.have.property('genre');",
              "        pm.expect(m).to.have.property('actors');",
              "        pm.expect(m).to.have.property('avgRating');",
              "        pm.expect(m).to.not.have.property('reviews');",
              "    });",
              "});",
              "",
              "pm.test('At least one movie has an imageUrl (seeded movies)', function () {",
              "    const movies = pm.response.json();",
              "    const withImage = movies.filter(m => m.imageUrl);",
              "    pm.expect(withImage.length).to.be.at.least(1);",
              "});",
              "",
              "pm.test('Movies are sorted descending by avgRating', function () {",
              "    const movies = pm.response.json();",
              "    for (let i = 1; i < movies.length; i++) {",
              "        pm.expect(movies[i].avgRating).to.be.at.most(movies[i - 1].avgRating);",
              "    }",
              "});"
            ]
          }
        }
      ],
